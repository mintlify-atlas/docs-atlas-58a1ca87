  "keyFeatures": [
    "Complete JSON Logic operator support (data access, logical, numeric, array, string operations)",
    "Multi-dialect SQL generation (BigQuery, Spanner, PostgreSQL, DuckDB, ClickHouse)",
    "Custom operator registration with dialect-aware support",
    "Schema validation with field type checking and enum validation",
    "Structured error handling with error codes and JSONPath locations",
    "Interactive REPL for testing and experimentation",
    "Thread-safe operator registry for custom extensions",
    "Support for both WHERE clauses and standalone conditions"
  ],
  "publicApiSurface": [
    "Transpile(dialect, jsonLogic) - Convert JSON Logic string to SQL WHERE clause",
    "TranspileCondition(dialect, jsonLogic) - Convert JSON Logic to SQL condition without WHERE",
    "NewTranspiler(dialect) - Create transpiler instance",
    "NewTranspilerWithConfig(config) - Create transpiler with custom configuration",
    "Transpiler.RegisterOperator(name, handler) - Register custom operator",
    "Transpiler.RegisterOperatorFunc(name, func) - Register custom operator function",
    "Transpiler.RegisterDialectAwareOperator(name, handler) - Register dialect-aware operator",
    "Transpiler.SetSchema(schema) - Configure schema validation",
    "NewSchema(fields) - Create schema from field definitions",
    "NewSchemaFromJSON(data) - Create schema from JSON",
    "NewSchemaFromFile(path) - Load schema from file",
    "NewOperatorRegistry() - Create custom operator registry",
    "AsTranspileError(err) - Extract structured error information",
    "IsErrorCode(err, code) - Check error code",
    "DialectBigQuery, DialectSpanner, DialectPostgreSQL, DialectDuckDB, DialectClickHouse - SQL dialect constants"
  ]
}
